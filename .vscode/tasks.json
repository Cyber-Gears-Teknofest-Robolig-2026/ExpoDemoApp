{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "expo-start",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "start"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(THIS_WILL_NEVER_MATCH)$",
          "file": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting project at|Starting Metro Bundler|Starting Metro",
          "endsPattern": "Waiting on|Logs for your project will appear below"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}